{
  "name": "restaurantpos",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "backend": "npm run dev --prefix backend",
    "backend:start": "npm run start --prefix backend",
    "test:minimal": "npm run test:minimal:frontend && npm run test:minimal:backend",
    "test:minimal:frontend": "tsc -p tsconfig.tests.json && node tests/reporting.test.js && node tests/cancel-log.test.js",
    "test:minimal:backend": "node backend/tests/api.test.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~51.0.0",
    "expo-dev-client": "~4.0.29",
    "expo-font": "~12.0.10",
    "expo-print": "~13.0.1",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-esc-pos-printer": "^4.3.3",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.45",
    "typescript": "^5.3.3"
  },
  "private": true
}
